<hc:Window x:Class="HandWritten_OCR.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        xmlns:behaviors="clr-namespace:HandWritten_OCR.Behaviors"
        xmlns:converters="clr-namespace:HandWritten_OCR.Converters"
        xmlns:vm="clr-namespace:HandWritten_OCR.ViewModels"
           xmlns:views="clr-namespace:HandWritten_OCR.Views"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel, IsDesignTimeCreatable=False}"
        Title="{Binding Title}"
        Height="820" Width="1100"
        MinHeight="480" MinWidth="720"
        WindowStartupLocation="CenterScreen">

    <hc:Window.DataContext>
        <vm:MainViewModel/>
    </hc:Window.DataContext>

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <converters:BoolToVisibilityConverter x:Key="InvBoolToVis" IsInverted="True"/>
        <converters:NullToVisibilityConverter x:Key="NullToVis"/>
        <converters:NullToVisibilityConverter x:Key="InvNullToVis" IsInverted="True"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="2*" MinHeight="200"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="*" MinHeight="120"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="12,8,12,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" MinWidth="140"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="200"/>
            </Grid.ColumnDefinitions>

            <!--Image list-->
            <hc:Card Grid.Column="0" Padding="0">
                <views:ImageListView/>
            </hc:Card>

            <GridSplitter Grid.Column="1" Width="8" HorizontalAlignment="Stretch"
                          Background="Transparent" Cursor="SizeWE"/>

            <!--Image panel-->
            <hc:Card Grid.Column="2" Padding="0">
                <Grid>
                    <views:ImageView/>
                </Grid>
            </hc:Card>

            <GridSplitter Grid.Column="3" Width="8" HorizontalAlignment="Stretch"
                          Background="Transparent" Cursor="SizeWE"/>

            <!--Results panel-->
            <hc:Card Grid.Column="4" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="{DynamicResource SecondaryRegionBrush}"
                            BorderBrush="{DynamicResource BorderRegionBrush}"
                            BorderThickness="0,0,0,1" Padding="14,10">
                        <DockPanel>
                            <TextBlock Text="Recognized Text"
                                       FontSize="13" FontWeight="Medium"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       VerticalAlignment="Center" DockPanel.Dock="Left"/>
                            <Button Content="Copy" DockPanel.Dock="Right"
                                    HorizontalAlignment="Right"
                                    Command="{Binding CopyTextCommand}"
                                    Style="{StaticResource ButtonInfo}"
                                    Padding="10,4" FontSize="12"
                                    Visibility="{Binding HasResult, Converter={StaticResource BoolToVis}}"/>
                        </DockPanel>
                    </Border>

                    <TextBlock Grid.Row="1"
                               Text="OCR results will appear here"
                               FontSize="14"
                               Foreground="{DynamicResource ThirdlyTextBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Visibility="{Binding HasResult, Converter={StaticResource InvBoolToVis}}"/>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                  Visibility="{Binding HasResult, Converter={StaticResource BoolToVis}}">
                        <TextBox Text="{Binding OcrText, Mode=OneWay}"
                                 VerticalAlignment="Top"
                                 TextWrapping="Wrap" AcceptsReturn="True"
                                 IsReadOnly="True" BorderThickness="0"
                                 FontSize="14"
                                 Foreground="{DynamicResource PrimaryTextBrush}"
                                 FontFamily="Consolas"
                                 Background="Transparent"
                                 Padding="14"/>
                    </ScrollViewer>

                </Grid>
            </hc:Card>
        </Grid>

        <!--Toolbar-->
        <hc:Card Grid.Row="1" Margin="12,4,12,4" Padding="8">
            <views:MenuButtons/>
        </hc:Card>

        <!--GridSplitter-->
        <GridSplitter Grid.Row="2" Height="8" HorizontalAlignment="Stretch"
                      Background="Transparent" Cursor="SizeNS"
                      ResizeDirection="Rows"/>

        <!--DataGrid panel-->
        <hc:Card Grid.Row="3" Margin="12,0,12,4" Padding="0">
            <views:DataGridView/>
        </hc:Card>

        <!--Status bar-->
        <Border Grid.Row="4"
                Background="{DynamicResource SecondaryRegionBrush}"
                BorderBrush="{DynamicResource BorderRegionBrush}"
                BorderThickness="0,1,0,0"
                Padding="14,6">
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="{DynamicResource SecondaryTextBrush}"
                       FontSize="12"/>
        </Border>

    </Grid>
</hc:Window>

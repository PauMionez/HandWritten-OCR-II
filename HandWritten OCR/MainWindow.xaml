<hc:Window x:Class="HandWritten_OCR.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        xmlns:behaviors="clr-namespace:HandWritten_OCR.Behaviors"
        xmlns:converters="clr-namespace:HandWritten_OCR.Converters"
        xmlns:vm="clr-namespace:HandWritten_OCR.ViewModels"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel, IsDesignTimeCreatable=False}"
        Title="{Binding Title}"
        Height="680" Width="1100"
        MinHeight="480" MinWidth="720"
        WindowStartupLocation="CenterScreen">

    <hc:Window.DataContext>
        <vm:MainViewModel/>
    </hc:Window.DataContext>

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <converters:BoolToVisibilityConverter x:Key="InvBoolToVis" IsInverted="True"/>
        <converters:NullToVisibilityConverter x:Key="NullToVis"/>
        <converters:NullToVisibilityConverter x:Key="InvNullToVis" IsInverted="True"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        
        <Grid Grid.Row="0" Margin="12,8,12,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
           
            <hc:Card Grid.Column="0" Padding="0">
                <Grid>

                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                Visibility="{Binding PreviewImage, Converter={StaticResource InvNullToVis}}">
                        <Border Width="60" Height="60" CornerRadius="30"
                                Background="{DynamicResource SecondaryRegionBrush}"
                                Margin="0,0,0,14">
                            <TextBlock Text="&#x1F5BC;" FontSize="28" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Drop image here"
                                   FontSize="15"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="or click Open Image below"
                                   FontSize="12"
                                   Foreground="{DynamicResource ThirdlyTextBrush}"
                                   HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>

                    <Image Source="{Binding PreviewImage}" Stretch="Uniform" Margin="8"
                           Visibility="{Binding PreviewImage, Converter={StaticResource NullToVis}}"/>

                    <Border Background="{DynamicResource BackgroundBrush}"
                            Opacity="0.85" CornerRadius="4"
                            Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVis}}">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            
                            <hc:LoadingCircle IsRunning="{Binding IsProcessing}" Width="40" Height="40" Margin="0,0,0,12"/>
                            
                            <TextBlock Text="Processing..."
                                       FontSize="15" FontWeight="Medium"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding StatusMessage}"
                                       FontSize="12"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       HorizontalAlignment="Center" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>

                    <i:Interaction.Behaviors>
                        <behaviors:DragDropBehavior Command="{Binding DropImageCommand}"/>
                    </i:Interaction.Behaviors>

                </Grid>
            </hc:Card>

            <GridSplitter Grid.Column="1" Width="8" HorizontalAlignment="Stretch" Background="Transparent" Cursor="SizeWE"/>

            <hc:Card Grid.Column="2" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="{DynamicResource SecondaryRegionBrush}"
                            BorderBrush="{DynamicResource BorderRegionBrush}"
                            BorderThickness="0,0,0,1" Padding="14,10">
                        <DockPanel>
                            <TextBlock Text="Recognized Text"
                                       FontSize="13" FontWeight="Medium"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       VerticalAlignment="Center" DockPanel.Dock="Left"/>
                            <Button Content="Copy" DockPanel.Dock="Right"
                                    HorizontalAlignment="Right"
                                    Command="{Binding CopyTextCommand}"
                                    Style="{StaticResource ButtonInfo}"
                                    Padding="10,4" FontSize="12"
                                    Visibility="{Binding HasResult, Converter={StaticResource BoolToVis}}"/>
                        </DockPanel>
                    </Border>

                    <TextBlock Grid.Row="1"
                               Text="OCR results will appear here"
                               FontSize="14"
                               Foreground="{DynamicResource ThirdlyTextBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Visibility="{Binding HasResult, Converter={StaticResource InvBoolToVis}}"/>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                  Visibility="{Binding HasResult, Converter={StaticResource BoolToVis}}">
                        <TextBox Text="{Binding OcrText, Mode=OneWay}" VerticalAlignment="Top"
                                 TextWrapping="Wrap" AcceptsReturn="True"
                                 IsReadOnly="True" BorderThickness="0"
                                 FontSize="14"
                                 Foreground="{DynamicResource PrimaryTextBrush}"
                                 FontFamily="Consolas"
                                 Background="Transparent"
                                 Padding="14"/>
                    </ScrollViewer>

                </Grid>
            </hc:Card>
        </Grid>

        <hc:Card Grid.Row="1" Margin="12,4,12,4" Padding="8">
            <StackPanel Orientation="Horizontal">
                <Button Content="Open Image" Margin="0,0,8,0"
                        Command="{Binding OpenImageCommand}"
                        Style="{StaticResource ButtonPrimary}"/>
                <Button Content="Run OCR" Margin="0,0,8,0"
                        Command="{Binding RunOcrCommand}"
                        Style="{StaticResource ButtonSuccess}"/>
                <Button Content="Clear"
                        Command="{Binding ClearAllCommand}"/>
            </StackPanel>
        </hc:Card>

        <Border Grid.Row="2"
                Background="{DynamicResource SecondaryRegionBrush}"
                BorderBrush="{DynamicResource BorderRegionBrush}"
                BorderThickness="0,1,0,0"
                Padding="14,6">
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="{DynamicResource SecondaryTextBrush}"
                       FontSize="12"/>
        </Border>

    </Grid>
</hc:Window>

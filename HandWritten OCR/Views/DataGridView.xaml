<UserControl x:Class="HandWritten_OCR.Views.DataGridView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:HandWritten_OCR.Converters"
             xmlns:vm="clr-namespace:HandWritten_OCR.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:MainViewModel, IsDesignTimeCreatable=False}"
             d:DesignHeight="200" d:DesignWidth="800">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <converters:BoolToVisibilityConverter x:Key="InvBoolToVis" IsInverted="True"/>
        <converters:NullToVisibilityConverter x:Key="NullToVis"/>
        <converters:NullToVisibilityConverter x:Key="InvNullToVis" IsInverted="True"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Menu buttons -->
        <Border Grid.Row="0"
                Background="{DynamicResource SecondaryRegionBrush}"
                BorderBrush="{DynamicResource BorderRegionBrush}"
                BorderThickness="0,0,0,1" Padding="14,8">
            <DockPanel>
                <TextBlock Text="Data Grid"
                           FontSize="13" FontWeight="Medium"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           VerticalAlignment="Center" DockPanel.Dock="Left"
                           Margin="0,0,16,0"/>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Button Content="Import Template"
                            Margin="0,0,6,0"
                            Command="{Binding ImportTemplateCommand}"
                            Style="{StaticResource ButtonInfo}"
                            Padding="8,3" FontSize="12"/>
                    <Button Content="Add Row"
                            Margin="0,0,6,0"
                            Command="{Binding AddRowCommand}"
                            Padding="8,3" FontSize="12"
                            Visibility="{Binding HasGridData, Converter={StaticResource BoolToVis}}"/>
                    <Button Content="Delete Row"
                            Margin="0,0,6,0"
                            Command="{Binding DeleteRowCommand}"
                            Padding="8,3" FontSize="12"
                            Visibility="{Binding HasGridData, Converter={StaticResource BoolToVis}}"/>
                    <Button Content="Export"
                            Command="{Binding ExportCommand}"
                            Style="{StaticResource ButtonSuccess}"
                            Padding="8,3" FontSize="12"
                            Visibility="{Binding HasGridData, Converter={StaticResource BoolToVis}}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <TextBlock Grid.Row="1"
                   Text="Import an Excel template to load column headers"
                   FontSize="13"
                   Foreground="{DynamicResource ThirdlyTextBrush}"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Visibility="{Binding HasGridData, Converter={StaticResource InvBoolToVis}}"/>

        <!-- DataGrid -->
        <DataGrid Grid.Row="1"
                  x:Name="OcrDataGrid"
                  ItemsSource="{Binding GridView}"
                  AutoGenerateColumns="True"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  SelectionMode="Single"
                  SelectionUnit="Cell"
                  GridLinesVisibility="All"
                  HeadersVisibility="Column"
                  RowHeight="28"
                  FontSize="13"
                  Visibility="{Binding HasGridData, Converter={StaticResource BoolToVis}}"
                  CurrentCellChanged="OcrDataGrid_CurrentCellChanged"/>
    </Grid>
</UserControl>

<UserControl x:Class="HandWritten_OCR.Views.MenuButtons"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:converters="clr-namespace:HandWritten_OCR.Converters"
             xmlns:local="clr-namespace:HandWritten_OCR.Views"
             mc:Ignorable="d" >
    
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <converters:BoolToVisibilityConverter x:Key="InvBoolToVis" IsInverted="True"/>
        <converters:NullToVisibilityConverter x:Key="NullToVis"/>
        <converters:NullToVisibilityConverter x:Key="InvNullToVis" IsInverted="True"/>
    </UserControl.Resources>


    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Engine / model / status row -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
            <TextBlock Text="OCR Engine:" VerticalAlignment="Center"
                       Margin="0,0,8,0" FontSize="12"
                       Foreground="{DynamicResource SecondaryTextBrush}"/>
            <RadioButton Content="TrOCR"
                         IsChecked="{Binding IsTrOcrSelected, Mode=TwoWay}"
                         GroupName="OcrEngine" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <RadioButton Content="PaddleOCR"
                         IsChecked="{Binding IsPaddleOcrSelected, Mode=TwoWay}"
                         GroupName="OcrEngine" VerticalAlignment="Center"/>

            <!-- Language selector — visible when PaddleOCR is selected -->
            <ComboBox SelectedIndex="{Binding SelectedPaddleLangIndex}"
                      Margin="12,0,0,0" MinWidth="160" VerticalAlignment="Center"
                      Visibility="{Binding IsPaddleOcrSelected, Converter={StaticResource BoolToVis}}">
                <ComboBoxItem Content="English ★"/>
                <ComboBoxItem Content="Chinese (Simplified)"/>
                <ComboBoxItem Content="French"/>
                <ComboBoxItem Content="German"/>
            </ComboBox>

            <!-- Server status indicator — visible when PaddleOCR is selected -->
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                        Margin="12,0,0,0"
                        Visibility="{Binding IsPaddleOcrSelected, Converter={StaticResource BoolToVis}}">
                <Ellipse Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,5,0">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Setter Property="Fill" Value="Orange"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsPaddleServerReady}" Value="True">
                                    <Setter Property="Fill" Value="#2ECC71"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>
                <TextBlock Text="{Binding PaddleServerStatusText}" FontSize="11"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource SecondaryTextBrush}"/>
            </StackPanel>
        </StackPanel>

        <!-- Action buttons row -->
        <StackPanel Grid.Row="1" Orientation="Horizontal">
            <Button Content="Open Image" Margin="0,0,8,0"
             Command="{Binding OpenImageCommand}"
             Style="{StaticResource ButtonPrimary}"/>

            <!-- Toggle: "Draw Regions" / "Stop Drawing" — only when image loaded -->
            <Button Content="{Binding RegionModeLabel}"
             Margin="0,0,8,0"
             Command="{Binding ToggleRegionModeCommand}"
             Style="{StaticResource ButtonInfo}"
             Visibility="{Binding PreviewImage, Converter={StaticResource NullToVis}}"/>

            <!-- Clear Regions — only when boxes exist -->
            <Button Content="Clear Regions" Margin="0,0,8,0"
             Command="{Binding ClearBoxesCommand}"
             Visibility="{Binding HasRegionBoxes, Converter={StaticResource BoolToVis}}"/>

            <Button Content="Run OCR" Margin="0,0,8,0"
             Command="{Binding RunOcrCommand}"
             Style="{StaticResource ButtonSuccess}"/>
            <Button Content="Clear"
             Command="{Binding ClearAllCommand}"/>

            <Button Content="↺" Command="{Binding RotateLeftCommand}"
             Visibility="{Binding PreviewImage, Converter={StaticResource NullToVis}}"/>
            <Button Content="↻" Command="{Binding RotateRightCommand}"
             Visibility="{Binding PreviewImage, Converter={StaticResource NullToVis}}"/>
        </StackPanel>
    </Grid>
</UserControl>
